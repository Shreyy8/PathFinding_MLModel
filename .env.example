# Backend API Server Configuration
# Copy this file to .env and adjust values as needed

# Server Settings
API_HOST=localhost
API_PORT=5000
API_DEBUG=False

# CORS Settings
# Comma-separated list of allowed origins
# Use wildcards for development: http://localhost:*
# Use specific ports for production: http://localhost:3000,http://localhost:8080
CORS_ORIGINS=http://localhost:*,http://127.0.0.1:*

# Image Processing Limits
# Maximum image file size in bytes (default: 10 MB)
MAX_IMAGE_SIZE=10485760
# Maximum image dimension in pixels (default: 4096)
MAX_IMAGE_DIMENSION=4096

# Session Settings
# Session timeout in seconds (default: 3600 = 1 hour)
SESSION_TIMEOUT=3600

# Logging Settings
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Model Settings
# Path to trained model checkpoint
MODEL_CHECKPOINT_PATH=models/best_model.pth
